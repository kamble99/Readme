Min-Max Algorithm Implementation
# Sample game tree
game_tree = {
'A': ['B', 'C'],
'B': ['D', 'E'],
'C': ['F', 'G'],
'D': 3,
'E': 5,
'F': 2,
'G': 9
}
def minimax(node, is_max):
# If leaf node, return value
if isinstance(game_tree[node], int):
return game_tree[node]
if is_max:
best_value = float('-inf')
for child in game_tree[node]:
value = minimax(child, False)
best_value = max(best_value, value)
return best_value
else:
best_value = float('inf')
for child in game_tree[node]:
value = minimax(child, True)
best_value = min(best_value, value)
return best_value
# Driver Code
optimal_value = minimax('A', True)
print("Optimal Value using Min-Max:", optimal_value)